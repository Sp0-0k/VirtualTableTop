# Caddy site block for vtt.5edice.com.
# Paste this into your existing Caddyfile (or import it via `import` directive).
# Caddy will provision a TLS cert automatically on first request.

vtt.5edice.com {
    encode gzip

    # API + Socket.IO go to Node. Caddy v2's reverse_proxy supports
    # WebSocket upgrades out of the box — no extra config needed.
    @backend path /api/* /socket.io/*
    reverse_proxy @backend localhost:3002

    # Everything else: static client with SPA fallback.
    root * /home/ubuntu/services/vtt/public
    try_files {path} /index.html
    file_server
}
