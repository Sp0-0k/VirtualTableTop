{
  "name": "vtt",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Single-campaign D&D virtual tabletop",
  "scripts": {
    "dev:server": "node --env-file=.env --import tsx --watch server/src/main.ts",
    "dev:client": "vite",
    "build:server": "node esbuild.config.mjs",
    "build:client": "vite build",
    "build": "npm run build:server && npm run build:client",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "cookie": "^0.7.0",
    "express": "^4.21.0",
    "file-type": "^19.0.0",
    "konva": "^9.3.22",
    "multer": "^1.4.5-lts.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-konva": "^18.2.14",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.0",
    "socket.io-client": "^4.8.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/cookie": "^0.6.0",
    "@types/express": "^4.17.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "canvas": "^3.2.3",
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
